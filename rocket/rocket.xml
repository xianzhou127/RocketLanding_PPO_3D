<mujoco model="falcon9">
    <compiler meshdir="." autolimits="true"/>

    <option timestep="0.002"/>

    <visual>
        <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0"/>
        <rgba haze="0.15 0.25 0.35 1"/>
    </visual>

    <asset>
        <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="1 1 1" width="512" height="512"/>
        
        <texture name="grid" type="2d" builtin="checker" rgb1="0.2 0.3 0.4" rgb2="0.1 0.15 0.2" width="512" height="512"/>
        <material name="ground_mat" texture="grid" texrepeat="20 20" texuniform="true" reflectance="0.1"/>

        <material name="fire_mat" rgba="1 0.4 0.1 0.7" reflectance="0" emission="1"/>
        
        <mesh name="body_mesh" file="body.obj"/>
        <mesh name="legs_mesh" file="legs.obj"/>
    </asset>

    <worldbody>
        <light directional="true" diffuse="0.8 0.8 0.8" specular="0.2 0.2 0.2" pos="0 0 50" dir="0 -1 -1" castshadow="true"/>

        <geom name="ground" type="plane" size="100 100 0.1" rgba=".2 .3 .4 1" contype="0" conaffinity="0"/>

        <body name="rocket_main" pos="0 0 2.5">
            <freejoint name="root"/>
            
            <inertial pos="0 0 12" mass="25000" diaginertia="4500000 4500000 50000"/>

            <site name="com_visual" pos="0 0 12" type="sphere" size="2" rgba="0 1 0 1" />

            <camera name="track_cam" mode="trackcom" pos="70.7 -70.7 10" xyaxes="0.707 0.707 0 0 0 1"/>

            <!-- 1. 远距离全景视角 (跟随火箭) -->
            <camera name="tracking_view" mode="trackcom" pos="0 -80 20" xyaxes="1 0 0 0 0.5 0.8"/>

            <!-- 2. 近距离侧面视角 (便于观察姿态和云朵/高度) -->
            <camera name="side_view" mode="trackcom" pos="30 0 15" xyaxes="0 1 0 0 0 1"/>

            <!-- 3. 发动机特写视角 (重点观测喷管姿态) -->
            <camera name="engine_view" mode="targetbodycom" target="engine" pos="0 -5 0" xyaxes="1 0 0 0 0 1"/>

            <!-- 箭载俯视：固定在火箭侧上方，镜头朝下看向发动机和地面 -->
            <!-- pos="2 0 20" 表示装在X轴偏移2(避免被箭体完全挡住)，高度20的位置 -->
            <camera name="gopro_down" mode="fixed" pos="2.5 0 20" xyaxes="0 -1 0 1 0 0" fovy="75"/>

            <!-- 上帝俯视：装在世界坐标系中，始终悬浮在火箭上方 100 米 -->
            <camera name="sky_top_down" mode="trackcom" pos="0 0 100" xyaxes="1 0 0 0 1 0"/>
            
            <geom name="visual_body" type="mesh" mesh="body_mesh" contype="0" conaffinity="0" rgba="0.8 0.8 0.8 1"/>
            
            <body name="legs" pos="0 0 0">
                <inertial pos="0 0 0" mass="2000" diaginertia="100 100 100"/>
                <geom name="visual_legs" type="mesh" mesh="legs_mesh" contype="0" conaffinity="0" rgba="0.5 0.5 0.5 1"/>
            </body>
            
            <geom name="collision_body" type="cylinder" size="1.8 23" pos="0 0 23" rgba="1 0 0 0.2"/>
            <geom name="pad_1" type="sphere" size="0.15" pos=" 9  0 -2" contype="1" conaffinity="1" rgba="1 0 0 0.5"/>
            <geom name="pad_2" type="sphere" size="0.15" pos="-9  0 -2" contype="1" conaffinity="1" rgba="1 0 0 0.5"/>
            <geom name="pad_3" type="sphere" size="0.15" pos=" 0 -9 -2" contype="1" conaffinity="1" rgba="1 0 0 0.5"/>
            <geom name="pad_4" type="sphere" size="0.15" pos=" 0  9 -2" contype="1" conaffinity="1" rgba="1 0 0 0.5"/>

            <body name="engine" pos="0 0 0">
                <inertial pos="0 0 0" mass="500" diaginertia="50 50 50"/>
                
                <joint name="gimbal_pitch" type="hinge" axis="1 0 0" range="-15 15" stiffness="1000" damping="450"/>
                <joint name="gimbal_yaw" type="hinge" axis="0 1 0" range="-15 15" stiffness="1000" damping="450"/>
                
                <site name="thrust_point" type="cylinder" size="0.2 0.1" rgba="1 0.5 0 1"/>

                <geom name="fire_geom" type="capsule" size="0.25 1.5" pos="0 0 -1.5" material="fire_mat" contype="0" conaffinity="0"/>
            </body>
        </body>
    </worldbody>

    <actuator>
        <position name="ctrl_gimbal_pitch" joint="gimbal_pitch" ctrlrange="-0.26 0.26" kp="50000"/>
        <position name="ctrl_gimbal_yaw" joint="gimbal_yaw" ctrlrange="-0.26 0.26" kp="50000"/>
        
        <general name="ctrl_thrust" site="thrust_point" gear="0 0 1 0 0 0" ctrlrange="0 539550"/>
    </actuator>

    <sensor>
        <gyro name="body_gyro" site="thrust_point"/>
        <accelerometer name="body_accel" site="thrust_point"/>
        <velocimeter name="body_vel" site="thrust_point"/>
    </sensor>
</mujoco>